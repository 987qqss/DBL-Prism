<UserControl x:Class="Shell.Views.CommandRunView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent">

    <UserControl.Resources>
        <!-- 布尔值转可见性转换器 -->
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />

        <!-- 状态节点模板 -->
        <DataTemplate x:Key="StateNodeTemplate">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- 状态圆点区域 -->
                <Grid Grid.Row="0" HorizontalAlignment="Center">
                    <!-- 光晕效果（活跃状态时显示） -->
                    <Ellipse Width="36"
                             Height="36"
                             Fill="{StaticResource AccentCyanBrush}"
                             Opacity="0.25"
                             Visibility="{Binding IsActive, Converter={StaticResource BooleanToVisibilityConverter}}" />
                    <!-- 状态圆点 -->
                    <Ellipse Width="20"
                             Height="20"
                             VerticalAlignment="Center"
                             HorizontalAlignment="Center">
                        <Ellipse.Style>
                            <Style TargetType="Ellipse">
                                <Setter Property="Fill" Value="#3A3A4A" />
                                <Setter Property="Stroke" Value="{StaticResource BorderBrushDark}" />
                                <Setter Property="StrokeThickness" Value="2" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsActive}" Value="True">
                                        <Setter Property="Fill" Value="{StaticResource AccentCyanBrush}" />
                                        <Setter Property="Stroke" Value="{StaticResource AccentCyanBrush}" />
                                        <Setter Property="StrokeThickness" Value="3" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding IsError}" Value="True">
                                        <Setter Property="Fill" Value="#E05555" />
                                        <Setter Property="Stroke" Value="#E05555" />
                                        <Setter Property="StrokeThickness" Value="3" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding IsCompleted}" Value="True">
                                        <Setter Property="Fill" Value="#4CAF50" />
                                        <Setter Property="Stroke" Value="#4CAF50" />
                                        <Setter Property="StrokeThickness" Value="2" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Ellipse.Style>
                    </Ellipse>
                </Grid>

                <!-- 状态名称 -->
                <TextBlock Grid.Row="1"
                           Text="{Binding Name}"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           FontSize="11"
                           HorizontalAlignment="Center"
                           Margin="0,6,0,0" />
            </Grid>
        </DataTemplate>

        <!-- 带连接线的状态节点模板 -->
        <DataTemplate x:Key="StateNodeWithConnectorTemplate">
            <StackPanel Orientation="Horizontal">
                <!-- 状态节点 -->
                <ContentPresenter Content="{Binding}"
                                  ContentTemplate="{StaticResource StateNodeTemplate}"
                                  VerticalAlignment="Center" />

                <!-- 连接线 + 箭头（非最后一项时显示） -->
                <Grid Width="55"
                      Visibility="{Binding ShowConnector, Converter={StaticResource BooleanToVisibilityConverter}}"
                      VerticalAlignment="Center"
                      Margin="4,0,4,0">
                    <!-- 连接线 -->
                    <Rectangle Height="3"
                               RadiusX="1.5"
                               RadiusY="1.5"
                               VerticalAlignment="Center"
                               Fill="#3A3A4A" />
                    <!-- 箭头 -->
                    <Polygon Points="0,-5 7,0 0,5"
                             Fill="#3A3A4A"
                             HorizontalAlignment="Right"
                             VerticalAlignment="Center" />
                </Grid>
            </StackPanel>
        </DataTemplate>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- 标题栏 -->
        <Border Grid.Row="0"
                Style="{StaticResource PanelBorderStyle}"
                Margin="0,0,0,8">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="▶"
                           FontSize="20"
                           Foreground="{StaticResource AccentCyanBrush}"
                           VerticalAlignment="Center" />
                <TextBlock Text="设备命令执行信息"
                           Foreground="{StaticResource TextPrimaryBrush}"
                           FontSize="16"
                           FontWeight="Bold"
                           VerticalAlignment="Center"
                           Margin="10,0,0,0" />
            </StackPanel>
        </Border>

        <!-- 主内容区 -->
        <Border Grid.Row="1"
                Style="{StaticResource PanelBorderStyle}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <!-- ==================== 状态机可视化区域 ==================== -->
                <Border Grid.Row="0"
                        Background="#0AFFFFFF"
                        CornerRadius="8"
                        Padding="16,14"
                        Margin="0,0,0,12"
                        BorderBrush="{StaticResource BorderBrushDark}"
                        BorderThickness="1">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <!-- 状态机标题 + 当前状态指示 -->
                        <StackPanel Grid.Row="0"
                                    Orientation="Horizontal"
                                    Margin="0,0,0,12">
                            <TextBlock Text="⏣"
                                       FontSize="18"
                                       Foreground="{StaticResource AccentCyanBrush}"
                                       VerticalAlignment="Center" />
                            <TextBlock Text="状态机"
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       FontSize="14"
                                       FontWeight="SemiBold"
                                       VerticalAlignment="Center"
                                       Margin="6,0,0,0" />
                            <Border CornerRadius="10"
                                    Padding="10,3"
                                    Margin="16,0,0,0"
                                    VerticalAlignment="Center"
                                    Background="#1AFFFFFF">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="当前状态："
                                               Foreground="{StaticResource TextSecondaryBrush}"
                                               FontSize="12"
                                               VerticalAlignment="Center" />
                                    <Ellipse Width="10"
                                             Height="10"
                                             Fill="{StaticResource AccentCyanBrush}"
                                             VerticalAlignment="Center"
                                             Margin="6,0,0,0" />
                                    <TextBlock Text="{Binding CurrentState}"
                                               Foreground="{StaticResource AccentCyanBrush}"
                                               FontSize="13"
                                               FontWeight="Bold"
                                               VerticalAlignment="Center"
                                               Margin="4,0,0,0" />
                                </StackPanel>
                            </Border>
                            <!-- 运行时间 -->
                            <TextBlock Text="{Binding ElapsedTime, StringFormat='运行时间：{0}'}"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       FontSize="11"
                                       VerticalAlignment="Center"
                                       Margin="20,0,0,0"
                                       Visibility="{Binding IsRunning, Converter={StaticResource BooleanToVisibilityConverter}, FallbackValue=Collapsed}" />
                        </StackPanel>

                        <!-- 状态流转图 -->
                        <Border Grid.Row="1"
                                Background="#05FFFFFF"
                                CornerRadius="6"
                                Padding="12,16"
                                Margin="0,0,0,6">
                            <ItemsControl ItemsSource="{Binding States}"
                                          HorizontalAlignment="Center">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <StackPanel Orientation="Horizontal" />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <ContentPresenter Content="{Binding}"
                                                          ContentTemplate="{StaticResource StateNodeWithConnectorTemplate}" />
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Border>

                        <!-- 状态说明 -->
                        <StackPanel Grid.Row="2"
                                    Orientation="Horizontal"
                                    HorizontalAlignment="Center"
                                    Margin="0,4,0,0">
                            <StackPanel Orientation="Horizontal" Margin="0,0,16,0">
                                <Ellipse Width="10" Height="10" Fill="{StaticResource AccentCyanBrush}" VerticalAlignment="Center" />
                                <TextBlock Text="当前状态"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           FontSize="10"
                                           Margin="4,0,0,0"
                                           VerticalAlignment="Center" />
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,16,0">
                                <Ellipse Width="10" Height="10" Fill="#4CAF50" VerticalAlignment="Center" />
                                <TextBlock Text="已完成"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           FontSize="10"
                                           Margin="4,0,0,0"
                                           VerticalAlignment="Center" />
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,16,0">
                                <Ellipse Width="10" Height="10" Fill="#3A3A4A" Stroke="{StaticResource BorderBrushDark}" StrokeThickness="1" VerticalAlignment="Center" />
                                <TextBlock Text="待执行"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           FontSize="10"
                                           Margin="4,0,0,0"
                                           VerticalAlignment="Center" />
                            </StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <Ellipse Width="10" Height="10" Fill="#E05555" VerticalAlignment="Center" />
                                <TextBlock Text="异常"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           FontSize="10"
                                           Margin="4,0,0,0"
                                           VerticalAlignment="Center" />
                            </StackPanel>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- ==================== 状态机控制按钮区 ==================== -->
                <Border Grid.Row="1"
                        Style="{StaticResource PanelBorderStyle}"
                        Margin="0,0,0,10"
                        Padding="12,10">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <!-- 主要操作按钮组 -->
                        <StackPanel Grid.Column="0"
                                    Orientation="Horizontal">
                            <!-- 启动按钮 -->
                            <Button Content="▶ 启动"
                                    Command="{Binding StartCommand}"
                                    Style="{StaticResource MenuFlatButtonStyle}"
                                    Background="#2D8C5A"
                                    Foreground="White"
                                    Margin="0,0,6,0"
                                    ToolTip="启动状态机" />
                            <!-- 暂停按钮 -->
                            <Button Content="⏸ 暂停"
                                    Command="{Binding PauseCommand}"
                                    Style="{StaticResource MenuFlatButtonStyle}"
                                    Background="#D4852A"
                                    Foreground="White"
                                    Margin="0,0,6,0"
                                    ToolTip="暂停状态机" />
                            <!-- 恢复按钮 -->
                            <Button Content="▶ 恢复"
                                    Command="{Binding ResumeCommand}"
                                    Style="{StaticResource MenuFlatButtonStyle}"
                                    Background="#2A6DB5"
                                    Foreground="White"
                                    Margin="0,0,6,0"
                                    ToolTip="恢复状态机运行" />
                            <!-- 停止按钮 -->
                            <Button Content="⏹ 停止"
                                    Command="{Binding StopCommand}"
                                    Style="{StaticResource MenuFlatButtonStyle}"
                                    Background="#C0392B"
                                    Foreground="White"
                                    Margin="0,0,6,0"
                                    ToolTip="停止状态机" />
                        </StackPanel>

                        <!-- 分隔线 -->
                        <Rectangle Grid.Column="1"
                                   Width="1"
                                   Fill="{StaticResource BorderBrushDark}"
                                   VerticalAlignment="Stretch"
                                   Margin="4,4" />

                        <!-- 辅助操作按钮组 -->
                        <StackPanel Grid.Column="2"
                                    Orientation="Horizontal">
                            <!-- 重置按钮 -->
                            <Button Content="↻ 重置"
                                    Command="{Binding ResetCommand}"
                                    Style="{StaticResource MenuFlatButtonStyle}"
                                    BorderBrush="{StaticResource AccentCyanBrush}"
                                    BorderThickness="1"
                                    Margin="0,0,6,0"
                                    ToolTip="重置状态机到初始状态" />
                            <!-- 刷新按钮 -->
                            <Button Content="⟳ 刷新状态"
                                    Command="{Binding RefreshCommand}"
                                    Style="{StaticResource MenuFlatButtonStyle}"
                                    BorderBrush="{StaticResource BorderBrushDark}"
                                    BorderThickness="1"
                                    ToolTip="刷新当前状态信息" />
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- ==================== 状态机信息摘要栏 ==================== -->
                <Border Grid.Row="2"
                        Background="#08FFFFFF"
                        CornerRadius="4"
                        Padding="10,6"
                        Margin="0,0,0,8">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="执行计数："
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   FontSize="11"
                                   VerticalAlignment="Center" />
                        <TextBlock Text="{Binding ExecutionCount}"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   FontSize="11"
                                   FontWeight="SemiBold"
                                   VerticalAlignment="Center"
                                   Margin="0,0,16,0" />
                        <TextBlock Text="最后操作："
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   FontSize="11"
                                   VerticalAlignment="Center" />
                        <TextBlock Text="{Binding LastAction}"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   FontSize="11"
                                   VerticalAlignment="Center"
                                   Margin="0,0,16,0" />
                        <TextBlock Text="状态机版本："
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   FontSize="11"
                                   VerticalAlignment="Center" />
                        <TextBlock Text="{Binding StateMachineVersion}"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   FontSize="11"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                </Border>

                <!-- ==================== 命令执行历史列表 ==================== -->
                <DataGrid Grid.Row="3"
                          ItemsSource="{Binding CommandHistory}"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          IsReadOnly="True"
                          Background="Transparent"
                          Foreground="{StaticResource TextPrimaryBrush}"
                          BorderBrush="{StaticResource BorderBrushDark}"
                          GridLinesVisibility="Horizontal"
                          HorizontalGridLinesBrush="{StaticResource BorderBrushDark}"
                          RowBackground="Transparent"
                          AlternatingRowBackground="#11FFFFFF"
                          RowHeight="32"
                          ColumnHeaderHeight="34">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="时间"
                                            Binding="{Binding Time}"
                                            Width="160" />
                        <DataGridTextColumn Header="操作"
                                            Binding="{Binding Command}"
                                            Width="140">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="{StaticResource AccentCyanBrush}" />
                                    <Setter Property="FontWeight" Value="SemiBold" />
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="状态"
                                            Binding="{Binding Status}"
                                            Width="100">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Status}" Value="成功">
                                            <Setter Property="Foreground" Value="#4CAF50" />
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding Status}" Value="失败">
                                            <Setter Property="Foreground" Value="#E05555" />
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding Status}" Value="执行中">
                                            <Setter Property="Foreground" Value="{StaticResource AccentCyanBrush}" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="结果详情"
                                            Binding="{Binding Result}"
                                            Width="*" />
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>
    </Grid>
</UserControl>