<UserControl x:Class="SettingsModule.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:prism="http://prismlibrary.com/"
             prism:ViewModelLocator.AutoWireViewModel="True"
             Background="#0F1626">
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="60"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#1E1E2E" BorderBrush="#313244" BorderThickness="1" CornerRadius="12" Padding="20">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="系统设置" FontSize="20" FontWeight="Bold" Foreground="#E2E8F0"/>
            </StackPanel>
        </Border>

        <Border Grid.Row="1" Margin="0,15,0,0" Background="#1E1E2E" BorderBrush="#313244" BorderThickness="1" CornerRadius="12" Padding="30">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="60"/>
                    <RowDefinition Height="60"/>
                    <RowDefinition Height="60"/>
                    <RowDefinition Height="60"/>
                    <RowDefinition Height="80"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="150"/>
                    <ColumnDefinition Width="250"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Text="IP地址:" Foreground="#94A3B8" VerticalAlignment="Center"/>
                <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding IpAddress}" 
                         Background="#252536" Foreground="White" BorderBrush="#313244" Height="35"/>

                <TextBlock Grid.Row="1" Grid.Column="0" Text="端口:" Foreground="#94A3B8" VerticalAlignment="Center"/>
                <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding Port}" 
                         Background="#252536" Foreground="White" BorderBrush="#313244" Height="35"/>

                <TextBlock Grid.Row="2" Grid.Column="0" Text="从站地址:" Foreground="#94A3B8" VerticalAlignment="Center"/>
                <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding SlaveAddress}" 
                         Background="#252536" Foreground="White" BorderBrush="#313244" Height="35"/>

                <TextBlock Grid.Row="3" Grid.Column="0" Text="自动连接:" Foreground="#94A3B8" VerticalAlignment="Center"/>
                <CheckBox Grid.Row="3" Grid.Column="1" IsChecked="{Binding AutoConnect}" 
                          Foreground="#E2E8F0" VerticalAlignment="Center"/>

                <StackPanel Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="3" Orientation="Horizontal">
                    <Button Content="测试连接" Command="{Binding TestConnectionCommand}" 
                            Style="{StaticResource MenuFlatButtonStyle}" Margin="0,0,10,0"
                            Background="#3B82F6" Foreground="White"/>
                    <Button Content="保存设置" Command="{Binding SaveSettingsCommand}" 
                            Style="{StaticResource MenuFlatButtonStyle}" Margin="0,0,10,0"
                            Background="#22C55E" Foreground="Black"/>
                    <Button Content="恢复默认" Command="{Binding RestoreDefaultsCommand}" 
                            Style="{StaticResource MenuFlatButtonStyle}"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>