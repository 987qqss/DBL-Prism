<UserControl x:Class="AlarmModule.Views.AlarmView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:AlarmModule.Converters"
             Background="#161625"
             >
    <UserControl.Resources>
        <converters:BoolToBrushConverter x:Key="BoolToBrushConverter"/>
        <converters:BooleanToConnectConverter x:Key="BooleanToConnectConverter"/>
        <converters:AlarmToStatusConverter x:Key="AlarmToStatusConverter"/>
        <Style x:Key="ButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#3B82F6"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                              CornerRadius="8" 
                              Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="60"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Border Grid.Row="0" Background="#1E1E2E" BorderBrush="#313244" BorderThickness="1" CornerRadius="12" Padding="20,0">
            <Grid>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="动环监控系统" FontSize="26" FontWeight="Bold" Foreground="#E2E8F0" VerticalAlignment="Center"/>
                    <Button Style="{StaticResource ButtonStyle}" Content="启用轮询" Command="{Binding ReadPollCommand}" Margin="15,0,0,0"/>
                    <Button Style="{StaticResource ButtonStyle}" Content="停止轮询" Command="{Binding StopPollCommand}" Margin="15,0,0,0"/>
                    <TextBlock Margin="60,0,10,0" VerticalAlignment="Center" Text="轮询状态：" Foreground="AntiqueWhite" FontSize="15"/>
                    <Ellipse Width="20" Height="20" Fill="{Binding IsPolling, Converter={StaticResource BooleanToConnectConverter}}" Margin="10,0,0,0"/>
                    <TextBlock Margin="60,0,10,0" VerticalAlignment="Center" Text="当前用户名：" Foreground="AntiqueWhite" FontSize="15"/>
                    <TextBlock Margin="0,0,10,0" VerticalAlignment="Center" Text="{Binding UserName}" Foreground="AntiqueWhite" FontSize="15"/>
                </StackPanel>
            </Grid>
        </Border>
        <ScrollViewer Grid.Row="1" Margin="0,15,0,15" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <WrapPanel HorizontalAlignment="Center">
                <Border Width="310" Height="185" Margin="10" Padding="18" Background="#1E1E2E" BorderBrush="#313244" BorderThickness="1" CornerRadius="14">
                    <StackPanel>
                        <DockPanel Margin="0,0,0,15">
                            <StackPanel Orientation="Horizontal" DockPanel.Dock="Right">
                                <TextBlock Text="{Binding Temperature.IsAlarm, Converter={StaticResource AlarmToStatusConverter}}" Foreground="#EF4444" FontWeight="Bold"/>
                            </StackPanel>
                            <TextBlock Text="温湿度传感器" FontSize="18" FontWeight="Bold" Foreground="#E2E8F0"/>
                        </DockPanel>
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition/>
                                <RowDefinition/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="90"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="温度" Foreground="#94A3B8" FontSize="15" VerticalAlignment="Center"/>
                            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="{Binding Temperature.Value}" Foreground="#FBBF24" FontSize="24" FontWeight="Bold"/>
                                <TextBlock Text=" ℃" Foreground="#FBBF24" FontSize="16" VerticalAlignment="Center" Margin="2,0,0,0"/>
                            </StackPanel>
                            <TextBlock Grid.Row="1" Text="湿度" Foreground="#94A3B8" FontSize="15" VerticalAlignment="Center" Margin="0,15,0,0"/>
                            <StackPanel Grid.Row="1" Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,15,0,0">
                                <TextBlock Text="{Binding Humidity.Value}" Foreground="#60A5FA" FontSize="24" FontWeight="Bold"/>
                                <TextBlock Text=" %" Foreground="#60A5FA" FontSize="16" VerticalAlignment="Center" Margin="2,0,0,0"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>
                <Border Width="310" Height="185" Margin="10" Padding="18" Background="#1E1E2E" BorderBrush="#313244" BorderThickness="1" CornerRadius="14">
                    <StackPanel>
                        <DockPanel Margin="0,0,0,15">
                            <StackPanel Orientation="Horizontal" DockPanel.Dock="Right" VerticalAlignment="Center">
                                <TextBlock Text="{Binding WISState.IsAlarm, Converter={StaticResource AlarmToStatusConverter}}" Foreground="#EF4444" FontWeight="Bold"/>
                            </StackPanel>
                            <TextBlock Text="水浸传感器" FontSize="18" FontWeight="Bold" Foreground="#E2E8F0" VerticalAlignment="Center"/>
                        </DockPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                            <Ellipse Width="12" Height="12" Fill="#22C55E" Margin="0,0,5,0"/>
                            <TextBlock Text="正常" Foreground="#94A3B8" VerticalAlignment="Center" Margin="0,0,15,0"/>
                            <Ellipse Width="12" Height="12" Fill="#EF4444" Margin="0,0,5,0"/>
                            <TextBlock Text="有水" Foreground="#94A3B8" VerticalAlignment="Center"/>
                        </StackPanel>
                        <Border Background="#252536" CornerRadius="10" Padding="15">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="当前状态：" Foreground="#94A3B8" VerticalAlignment="Center"/>
                                <Ellipse Width="20" Height="20" Fill="{Binding WISState.Value, Converter={StaticResource BoolToBrushConverter}}" Margin="10,0,0,0"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>
            </WrapPanel>
        </ScrollViewer>
    </Grid>
</UserControl>