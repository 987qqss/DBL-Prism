<UserControl x:Class="DeviceModule.Views.DeviceWizardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:prism="http://prismlibrary.com/"
             xmlns:vm="clr-namespace:DeviceModule.ViewModels"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:sys="clr-namespace:System;assembly=mscorlib"
             prism:ViewModelLocator.AutoWireViewModel="True"
             Background="#0F1626">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
    </UserControl.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="80" />
            <RowDefinition Height="*" />
            <RowDefinition Height="60" />
        </Grid.RowDefinitions>

        <!-- 步骤指示器头部 -->
        <Border Grid.Row="0" Background="#1E1E2E" Padding="24,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!-- 步骤指示器 -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Left">
                    <!-- 步骤1 -->
                    <Grid VerticalAlignment="Center">
                        <Ellipse Width="32" Height="32" Fill="{Binding Step1Color}" />
                        <TextBlock Text="1" FontSize="14" FontWeight="Bold" Foreground="White"
                                   HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Grid>
                    <TextBlock Text="选择协议" Foreground="{Binding Step1TextColor}" FontSize="13" VerticalAlignment="Center" Margin="8,0,12,0" />

                    <Line X1="0" Y1="16" X2="32" Y2="16" Stroke="{Binding Line1Color}" StrokeThickness="2" VerticalAlignment="Center" Margin="0,0,12,0" />

                    <!-- 步骤2 -->
                    <Grid VerticalAlignment="Center">
                        <Ellipse Width="32" Height="32" Fill="{Binding Step2Color}" />
                        <TextBlock Text="2" FontSize="14" FontWeight="Bold" Foreground="White"
                                   HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Grid>
                    <TextBlock Text="配置设备" Foreground="{Binding Step2TextColor}" FontSize="13" VerticalAlignment="Center" Margin="8,0,12,0" />

                    <Line X1="0" Y1="16" X2="32" Y2="16" Stroke="{Binding Line2Color}" StrokeThickness="2" VerticalAlignment="Center" Margin="0,0,12,0" />

                    <!-- 步骤3 -->
                    <Grid VerticalAlignment="Center">
                        <Ellipse Width="32" Height="32" Fill="{Binding Step3Color}" />
                        <TextBlock Text="3" FontSize="14" FontWeight="Bold" Foreground="White"
                                   HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Grid>
                    <TextBlock Text="测试连接" Foreground="{Binding Step3TextColor}" FontSize="13" VerticalAlignment="Center" Margin="8,0,12,0" />

                    <Line X1="0" Y1="16" X2="32" Y2="16" Stroke="{Binding Line3Color}" StrokeThickness="2" VerticalAlignment="Center" Margin="0,0,12,0" />

                    <!-- 步骤4 -->
                    <Grid VerticalAlignment="Center">
                        <Ellipse Width="32" Height="32" Fill="{Binding Step4Color}" />
                        <TextBlock Text="4" FontSize="14" FontWeight="Bold" Foreground="White"
                                   HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Grid>
                    <TextBlock Text="完成" Foreground="{Binding Step4TextColor}" FontSize="13" VerticalAlignment="Center" Margin="8,0,0,0" />
                </StackPanel>

                <!-- 标题 -->
                <Border Grid.Column="1" Background="#3B82F6" CornerRadius="4" Padding="16,8" VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="Circle" Width="8" Height="8" Foreground="White" VerticalAlignment="Center" Margin="0,0,8,0" />
                        <TextBlock Text="{Binding StepTitle}" FontSize="14" FontWeight="Bold" Foreground="White" />
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- 内容区域 -->
        <Border Grid.Row="1" Margin="16,8,16,8">
            <ContentControl Content="{Binding CurrentStepView}" />
        </Border>

        <!-- 底部按钮区域 -->
        <Border Grid.Row="2" Background="#1E1E2E" Padding="24,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!-- 取消按钮 -->
                <Button Grid.Column="0"
                        Content="取消"
                        Foreground="#94A3B8"
                        Background="Transparent"
                        BorderBrush="#94A3B8"
                        BorderThickness="1"
                        Padding="16,8"
                        VerticalAlignment="Center"
                        Command="{Binding CancelCommand}" />

                <!-- 按钮组 -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <!-- 上一步按钮 -->
                    <Button Command="{Binding PreviousStepCommand}"
                            IsEnabled="{Binding CanGoBack}"
                            Background="Transparent"
                            BorderBrush="#94A3B8"
                            BorderThickness="1"
                            Padding="16,8">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="ChevronLeft" Width="16" Height="16" Foreground="#94A3B8" VerticalAlignment="Center" />
                            <TextBlock Text="上一步" Foreground="#94A3B8" FontSize="13" VerticalAlignment="Center" Margin="4,0,0,0" />
                        </StackPanel>
                    </Button>

                    <!-- 下一步/完成按钮 -->
                    <Button Command="{Binding NextStepCommand}"
                            Margin="12,0,0,0"
                            Padding="16,8">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Background" Value="#3B82F6" />
                                <Setter Property="Foreground" Value="White" />
                                <Setter Property="BorderBrush" Value="Transparent" />
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}"
                                                    BorderBrush="{TemplateBinding BorderBrush}"
                                                    BorderThickness="1"
                                                    CornerRadius="4"
                                                    Padding="{TemplateBinding Padding}">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding CurrentStep}" Value="3">
                                        <Setter Property="Background" Value="#22C55E" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="{Binding NextButtonText}" FontSize="13" VerticalAlignment="Center" Foreground="White" />
                            <materialDesign:PackIcon Kind="Check" Width="16" Height="16" Foreground="White" Margin="4,0,0,0" VerticalAlignment="Center"
                                                    Visibility="{Binding ShowFinishIcon, Converter={StaticResource BooleanToVisibilityConverter}}" />
                            <materialDesign:PackIcon Kind="ChevronRight" Width="16" Height="16" Foreground="White" Margin="4,0,0,0" VerticalAlignment="Center"
                                                    Visibility="{Binding ShowNextIcon, Converter={StaticResource BooleanToVisibilityConverter}}" />
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>
