<UserControl x:Class="DeviceModule.Views.DeviceWizardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:prism="http://prismlibrary.com/"
             xmlns:vm="clr-namespace:DeviceModule.ViewModels"
             xmlns:m="clr-namespace:Core.Models;assembly=Core"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             prism:ViewModelLocator.AutoWireViewModel="True"
             Background="#0F1626">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="80" />
            <RowDefinition Height="*" />
            <RowDefinition Height="60" />
        </Grid.RowDefinitions>
        
        <Border Grid.Row="0" Background="#1E1E2E" Padding="16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                
                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <Border Width="32" Height="32" CornerRadius="16" Background="#3B82F6" Margin="0,0,12,0">
                        <TextBlock Text="1" FontSize="16" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <Border Width="32" Height="32" CornerRadius="16" Background="#2A2A4A" Margin="0,0,12,0">
                        <TextBlock Text="2" FontSize="16" FontWeight="Bold" Foreground="#6B7280" HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <Border Width="32" Height="32" CornerRadius="16" Background="#2A2A4A" Margin="0,0,12,0">
                        <TextBlock Text="3" FontSize="16" FontWeight="Bold" Foreground="#6B7280" HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <Border Width="32" Height="32" CornerRadius="16" Background="#2A2A4A" Margin="0,0,12,0">
                        <TextBlock Text="4" FontSize="16" FontWeight="Bold" Foreground="#6B7280" HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                </StackPanel>
                
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="{Binding StepTitle}" FontSize="16" FontWeight="Bold" Foreground="#E2E8F0" />
                </StackPanel>
            </Grid>
        </Border>
        
        <Grid Grid.Row="1">
            <ContentControl Content="{Binding CurrentStepView}" />
        </Grid>
        
        <Border Grid.Row="2" Background="#1E1E2E" Padding="16">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button x:Name="BtnBack" 
                        Style="{StaticResource FlatButtonStyle}"
                        Command="{Binding PreviousStepCommand}"
                        IsEnabled="{Binding CanGoBack}">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="ChevronLeft" Width="16" Height="16" Foreground="#94A3B8" />
                        <TextBlock Text="上一步" Foreground="#94A3B8" Margin="4,0,0,0" />
                    </StackPanel>
                </Button>
                
                <Button x:Name="BtnNext" 
                        Style="{StaticResource PrimaryButtonStyle}"
                        Command="{Binding NextStepCommand}"
                        Margin="8,0,0,0">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="{Binding NextButtonText}" Foreground="White" />
                        <materialDesign:PackIcon Kind="ChevronRight" Width="16" Height="16" Foreground="White" Margin="4,0,0,0" />
                    </StackPanel>
                </Button>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>