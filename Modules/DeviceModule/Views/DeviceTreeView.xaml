<UserControl x:Class="DeviceModule.Views.DeviceTreeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:prism="http://prismlibrary.com/"
             xmlns:vm="clr-namespace:DeviceModule.ViewModels"
             xmlns:m="clr-namespace:Core.Models;assembly=Core"
             xmlns:i="clr-namespace:Core.Interfaces;assembly=Core"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             prism:ViewModelLocator.AutoWireViewModel="True"
             Background="#1B1B2F">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="50" />
            <RowDefinition Height="*" />
            <RowDefinition Height="40" />
        </Grid.RowDefinitions>
        
        <Border Grid.Row="0" Background="#1E1E2E" Padding="12">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="设备列表" FontSize="14" FontWeight="Bold" Foreground="#E2E8F0" />
                <Button x:Name="BtnAddProductionLine" 
                        Margin="8,0,0,0" 
                        Width="24" Height="24"
                        Background="#3B82F6"
                        Command="{Binding AddProductionLineCommand}"
                        ToolTip="添加产线"
                        Cursor="Hand">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" 
                                    CornerRadius="12" 
                                    Width="24" Height="24">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                    <TextBlock Text="+" FontSize="16" Foreground="White" />
                </Button>
            </StackPanel>
        </Border>
        
        <TreeView Grid.Row="1" 
                  x:Name="DeviceTree"
                  ItemsSource="{Binding ProductionLines}">
            <TreeView.Resources>
                <HierarchicalDataTemplate DataType="{x:Type m:ProductionLineModel}" ItemsSource="{Binding Devices}">
                    <StackPanel Orientation="Horizontal" Height="32" VerticalAlignment="Center">
                        <materialDesign:PackIcon Kind="Folder" Width="16" Height="16" Foreground="#FBBF24" Margin="0,0,8,0" />
                        <TextBlock Text="{Binding Name}" Foreground="#E2E8F0" FontSize="13" />
                    </StackPanel>
                </HierarchicalDataTemplate>
                
                <HierarchicalDataTemplate DataType="{x:Type m:DeviceModel}" ItemsSource="{Binding Commands}">
                    <StackPanel Orientation="Horizontal" Height="32" VerticalAlignment="Center">
                        <materialDesign:PackIcon x:Name="DeviceIcon" Width="16" Height="16" Margin="0,0,8,0">
                            <materialDesign:PackIcon.Style>
                                <Style TargetType="materialDesign:PackIcon">
                                    <Setter Property="Kind" Value="Server" />
                                    <Setter Property="Foreground" Value="#6B7280" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Status}" Value="{x:Static i:DeviceStatus.Online}">
                                            <Setter Property="Foreground" Value="#22C55E" />
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding Status}" Value="{x:Static i:DeviceStatus.Offline}">
                                            <Setter Property="Foreground" Value="#EF4444" />
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding Status}" Value="{x:Static i:DeviceStatus.NotConfigured}">
                                            <Setter Property="Foreground" Value="#F59E0B" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </materialDesign:PackIcon.Style>
                        </materialDesign:PackIcon>
                        <TextBlock Text="{Binding Name}" Foreground="#E2E8F0" FontSize="13" />
                        <Ellipse x:Name="StatusDot" Width="8" Height="8" Margin="8,0,0,0">
                            <Ellipse.Style>
                                <Style TargetType="Ellipse">
                                    <Setter Property="Fill" Value="#6B7280" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Status}" Value="{x:Static i:DeviceStatus.Online}">
                                            <Setter Property="Fill" Value="#22C55E" />
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding Status}" Value="{x:Static i:DeviceStatus.Offline}">
                                            <Setter Property="Fill" Value="#EF4444" />
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding Status}" Value="{x:Static i:DeviceStatus.NotConfigured}">
                                            <Setter Property="Fill" Value="#F59E0B" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Ellipse.Style>
                        </Ellipse>
                    </StackPanel>
                </HierarchicalDataTemplate>
                
                <DataTemplate DataType="{x:Type m:DeviceCommand}">
                    <StackPanel Orientation="Horizontal" Height="28" VerticalAlignment="Center">
                        <materialDesign:PackIcon Kind="ChevronRight" Width="14" Height="14" Foreground="#6B7280" Margin="8,0,6,0" />
                        <TextBlock Text="{Binding Name}" Foreground="#94A3B8" FontSize="12" />
                    </StackPanel>
                </DataTemplate>
            </TreeView.Resources>
        </TreeView>
        
        <Border Grid.Row="2" Background="#1E1E2E" Padding="8">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <Button Style="{StaticResource MenuFlatButtonStyle}" Command="{Binding ExpandAllCommand}">
                    <TextBlock Text="展开全部" FontSize="11" Foreground="#94A3B8" />
                </Button>
                <Button Style="{StaticResource MenuFlatButtonStyle}" Command="{Binding CollapseAllCommand}" Margin="16,0,0,0">
                    <TextBlock Text="折叠全部" FontSize="11" Foreground="#94A3B8" />
                </Button>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>