<UserControl x:Class="DeviceModule.Views.DeviceConfigView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:DeviceModule.ViewModels"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             Background="#0F1626">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="60" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#1E1E2E" CornerRadius="8" Padding="16">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <materialDesign:PackIcon Kind="Cog" Width="20" Height="20" Foreground="#3B82F6" Margin="0,0,8,0" />
                <TextBlock Text="配置设备信息" FontSize="14" FontWeight="Bold" Foreground="#E2E8F0" />
            </StackPanel>
        </Border>

        <ScrollViewer Grid.Row="1" Margin="0,16,0,0" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <!-- 基础信息 -->
                <Border Background="#1E1E2E" CornerRadius="8" Padding="16" Margin="0,0,0,12">
                    <StackPanel>
                        <TextBlock Text="基础信息" FontSize="13" FontWeight="Bold" Foreground="#94A3B8" Margin="0,0,0,12" />

                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="100" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="设备名称" Foreground="#E2E8F0" VerticalAlignment="Center" />
                            <TextBox Grid.Column="1"
                                     Text="{Binding NewDevice.Name, UpdateSourceTrigger=PropertyChanged}"
                                     Background="#0F1626"
                                     Foreground="#E2E8F0"
                                     BorderBrush="#2A2A4A"
                                     CaretBrush="#3B82F6"
                                     SelectionBrush="#3B82F6"
                                     Padding="8,6" />
                        </Grid>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="100" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="通讯协议" Foreground="#E2E8F0" VerticalAlignment="Center" />
                            <Border Grid.Column="1" Background="#0F1626" CornerRadius="4" BorderBrush="#2A2A4A" BorderThickness="1" Padding="8,6">
                                <TextBlock Text="{Binding NewDevice.ProtocolType}" Foreground="#22C55E" />
                            </Border>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- 网络配置 -->
                <Border Background="#1E1E2E" CornerRadius="8" Padding="16" Margin="0,0,0,12">
                    <StackPanel>
                        <TextBlock Text="网络配置" FontSize="13" FontWeight="Bold" Foreground="#94A3B8" Margin="0,0,0,12" />

                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="100" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="IP地址" Foreground="#E2E8F0" VerticalAlignment="Center" />
                            <TextBox Grid.Column="1"
                                     Text="{Binding IpAddress, UpdateSourceTrigger=PropertyChanged}"
                                     Background="#0F1626"
                                     Foreground="#E2E8F0"
                                     BorderBrush="#2A2A4A"
                                     CaretBrush="#3B82F6"
                                     SelectionBrush="#3B82F6"
                                     Padding="8,6" />
                        </Grid>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="100" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="端口" Foreground="#E2E8F0" VerticalAlignment="Center" />
                            <TextBox Grid.Column="1"
                                     Text="{Binding Port, UpdateSourceTrigger=PropertyChanged}"
                                     Background="#0F1626"
                                     Foreground="#E2E8F0"
                                     BorderBrush="#2A2A4A"
                                     CaretBrush="#3B82F6"
                                     SelectionBrush="#3B82F6"
                                     Padding="8,6" />
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Modbus 配置 -->
                <Border Background="#1E1E2E" CornerRadius="8" Padding="16" Margin="0,0,0,12">
                    <StackPanel>
                        <TextBlock Text="Modbus 配置" FontSize="13" FontWeight="Bold" Foreground="#94A3B8" Margin="0,0,0,12" />

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="100" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="从站地址" Foreground="#E2E8F0" VerticalAlignment="Center" />
                            <TextBox Grid.Column="1"
                                     Text="{Binding SlaveId, UpdateSourceTrigger=PropertyChanged}"
                                     Background="#0F1626"
                                     Foreground="#E2E8F0"
                                     BorderBrush="#2A2A4A"
                                     CaretBrush="#3B82F6"
                                     SelectionBrush="#3B82F6"
                                     Padding="8,6" />
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- 串口配置 -->
                <Border Background="#1E1E2E" CornerRadius="8" Padding="16" Margin="0,0,0,12">
                    <StackPanel>
                        <TextBlock Text="串口配置" FontSize="13" FontWeight="Bold" Foreground="#94A3B8" Margin="0,0,0,12" />

                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="100" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="串口名称" Foreground="#E2E8F0" VerticalAlignment="Center" />
                            <ComboBox Grid.Column="1"
                                      ItemsSource="{Binding AvailablePorts}"
                                      SelectedItem="{Binding SerialPortName}"
                                      Background="#0F1626"
                                      Foreground="#E2E8F0"
                                      BorderBrush="#2A2A4A"
                                      Padding="8,6" />
                        </Grid>

                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="100" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="波特率" Foreground="#E2E8F0" VerticalAlignment="Center" />
                            <ComboBox Grid.Column="1"
                                      ItemsSource="{Binding BaudRates}"
                                      SelectedItem="{Binding BaudRate}"
                                      Background="#0F1626"
                                      Foreground="#E2E8F0"
                                      BorderBrush="#2A2A4A"
                                      Padding="8,6" />
                        </Grid>

                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="100" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="数据位" Foreground="#E2E8F0" VerticalAlignment="Center" />
                            <ComboBox Grid.Column="1"
                                      Text="{Binding DataBits}"
                                      Background="#0F1626"
                                      Foreground="#E2E8F0"
                                      BorderBrush="#2A2A4A"
                                      Padding="8,6"
                                      IsEditable="True" />
                        </Grid>

                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="100" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="奇偶校验" Foreground="#E2E8F0" VerticalAlignment="Center" />
                            <ComboBox Grid.Column="1"
                                      ItemsSource="{Binding ParityOptions}"
                                      SelectedItem="{Binding Parity}"
                                      Background="#0F1626"
                                      Foreground="#E2E8F0"
                                      BorderBrush="#2A2A4A"
                                      Padding="8,6" />
                        </Grid>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="100" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="停止位" Foreground="#E2E8F0" VerticalAlignment="Center" />
                            <ComboBox Grid.Column="1"
                                      ItemsSource="{Binding StopBitsOptions}"
                                      SelectedItem="{Binding StopBits}"
                                      Background="#0F1626"
                                      Foreground="#E2E8F0"
                                      BorderBrush="#2A2A4A"
                                      Padding="8,6" />
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- 西门子 S7 配置 -->
                <Border Background="#1E1E2E" CornerRadius="8" Padding="16" Margin="0,0,0,12">
                    <StackPanel>
                        <TextBlock Text="西门子 S7 配置" FontSize="13" FontWeight="Bold" Foreground="#94A3B8" Margin="0,0,0,12" />

                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="100" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Rack" Foreground="#E2E8F0" VerticalAlignment="Center" />
                            <TextBox Grid.Column="1"
                                     Text="{Binding S7Rack, UpdateSourceTrigger=PropertyChanged}"
                                     Background="#0F1626"
                                     Foreground="#E2E8F0"
                                     BorderBrush="#2A2A4A"
                                     CaretBrush="#3B82F6"
                                     SelectionBrush="#3B82F6"
                                     Padding="8,6" />
                        </Grid>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="100" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Slot" Foreground="#E2E8F0" VerticalAlignment="Center" />
                            <TextBox Grid.Column="1"
                                     Text="{Binding S7Slot, UpdateSourceTrigger=PropertyChanged}"
                                     Background="#0F1626"
                                     Foreground="#E2E8F0"
                                     BorderBrush="#2A2A4A"
                                     CaretBrush="#3B82F6"
                                     SelectionBrush="#3B82F6"
                                     Padding="8,6" />
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- 高级配置 -->
                <Border Background="#1E1E2E" CornerRadius="8" Padding="16">
                    <StackPanel>
                        <TextBlock Text="高级配置" FontSize="13" FontWeight="Bold" Foreground="#94A3B8" Margin="0,0,0,12" />

                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="100" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="超时(ms)" Foreground="#E2E8F0" VerticalAlignment="Center" />
                            <TextBox Grid.Column="1"
                                     Text="{Binding Timeout, UpdateSourceTrigger=PropertyChanged}"
                                     Background="#0F1626"
                                     Foreground="#E2E8F0"
                                     BorderBrush="#2A2A4A"
                                     CaretBrush="#3B82F6"
                                     SelectionBrush="#3B82F6"
                                     Padding="8,6" />
                        </Grid>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="100" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="重试次数" Foreground="#E2E8F0" VerticalAlignment="Center" />
                            <TextBox Grid.Column="1"
                                     Text="{Binding RetryCount, UpdateSourceTrigger=PropertyChanged}"
                                     Background="#0F1626"
                                     Foreground="#E2E8F0"
                                     BorderBrush="#2A2A4A"
                                     CaretBrush="#3B82F6"
                                     SelectionBrush="#3B82F6"
                                     Padding="8,6" />
                        </Grid>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
