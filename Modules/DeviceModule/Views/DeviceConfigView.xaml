<UserControl x:Class="DeviceModule.Views.DeviceConfigView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:DeviceModule.ViewModels"
             xmlns:m="clr-namespace:Core.Models;assembly=Core"
             Background="#0F1626">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="60" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        
        <Border Grid.Row="0" Background="#1E1E2E" CornerRadius="8" Padding="16">
            <TextBlock Text="配置设备信息" FontSize="14" FontWeight="Bold" Foreground="#E2E8F0" />
        </Border>
        
        <StackPanel Grid.Row="1" Margin="0,16,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="200" />
                    <ColumnDefinition Width="300" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                
                <TextBlock Grid.Column="0" Text="设备名称" Foreground="#94A3B8" Margin="0,8,0,0" />
                <TextBox Grid.Column="1" 
                         Text="{Binding NewDevice.Name}" 
                         Background="#1E1E2E" 
                         Foreground="#E2E8F0"
                         BorderBrush="#2A2A4A"
                         Margin="0,4,0,0"
                         Padding="8" />
                
                <TextBlock Grid.Column="0" Text="通讯协议" Foreground="#94A3B8" Margin="0,16,0,0" />
                <TextBlock Grid.Column="1" 
                           Text="{Binding NewDevice.ProtocolType}" 
                           Foreground="#E2E8F0"
                           Margin="0,12,0,0" />
                
                <TextBlock Grid.Column="0" Text="IP地址" Foreground="#94A3B8" Margin="0,16,0,0" />
                <TextBox Grid.Column="1" 
                         Text="{Binding NewDevice.IpAddress}" 
                         Background="#1E1E2E" 
                         Foreground="#E2E8F0"
                         BorderBrush="#2A2A4A"
                         Margin="0,12,0,0"
                         Padding="8" />
                
                <TextBlock Grid.Column="0" Text="端口" Foreground="#94A3B8" Margin="0,16,0,0" />
                <TextBox Grid.Column="1" 
                         Text="{Binding NewDevice.Port}" 
                         Background="#1E1E2E" 
                         Foreground="#E2E8F0"
                         BorderBrush="#2A2A4A"
                         Margin="0,12,0,0"
                         Padding="8" />
                
                <TextBlock Grid.Column="0" Text="从站地址" Foreground="#94A3B8" Margin="0,16,0,0" />
                <TextBox Grid.Column="1" 
                         Text="{Binding NewDevice.SlaveId}" 
                         Background="#1E1E2E" 
                         Foreground="#E2E8F0"
                         BorderBrush="#2A2A4A"
                         Margin="0,12,0,0"
                         Padding="8" />
                
                <TextBlock Grid.Column="0" Text="串口名称" Foreground="#94A3B8" Margin="0,16,0,0" />
                <ComboBox Grid.Column="1" 
                          ItemsSource="{Binding AvailablePorts}"
                          SelectedItem="{Binding NewDevice.SerialPortName}"
                          Background="#1E1E2E"
                          Foreground="#E2E8F0"
                          BorderBrush="#2A2A4A"
                          Margin="0,12,0,0"
                          Padding="8" />
                
                <TextBlock Grid.Column="0" Text="波特率" Foreground="#94A3B8" Margin="0,16,0,0" />
                <ComboBox Grid.Column="1" 
                          ItemsSource="{Binding BaudRates}"
                          SelectedItem="{Binding NewDevice.BaudRate}"
                          Background="#1E1E2E"
                          Foreground="#E2E8F0"
                          BorderBrush="#2A2A4A"
                          Margin="0,12,0,0"
                          Padding="8" />
                
                <TextBlock Grid.Column="0" Text="数据位" Foreground="#94A3B8" Margin="0,16,0,0" />
                <TextBox Grid.Column="1" 
                         Text="{Binding NewDevice.DataBits}" 
                         Background="#1E1E2E" 
                         Foreground="#E2E8F0"
                         BorderBrush="#2A2A4A"
                         Margin="0,12,0,0"
                         Padding="8" />
                
                <TextBlock Grid.Column="0" Text="奇偶校验" Foreground="#94A3B8" Margin="0,16,0,0" />
                <ComboBox Grid.Column="1" 
                          ItemsSource="{Binding ParityOptions}"
                          SelectedItem="{Binding NewDevice.Parity}"
                          Background="#1E1E2E"
                          Foreground="#E2E8F0"
                          BorderBrush="#2A2A4A"
                          Margin="0,12,0,0"
                          Padding="8" />
                
                <TextBlock Grid.Column="0" Text="停止位" Foreground="#94A3B8" Margin="0,16,0,0" />
                <ComboBox Grid.Column="1" 
                          ItemsSource="{Binding StopBitsOptions}"
                          SelectedItem="{Binding NewDevice.StopBits}"
                          Background="#1E1E2E"
                          Foreground="#E2E8F0"
                          BorderBrush="#2A2A4A"
                          Margin="0,12,0,0"
                          Padding="8" />
                
                <TextBlock Grid.Column="0" Text="S7 Rack" Foreground="#94A3B8" Margin="0,16,0,0" />
                <TextBox Grid.Column="1" 
                         Text="{Binding NewDevice.S7Rack}" 
                         Background="#1E1E2E" 
                         Foreground="#E2E8F0"
                         BorderBrush="#2A2A4A"
                         Margin="0,12,0,0"
                         Padding="8" />
                
                <TextBlock Grid.Column="0" Text="S7 Slot" Foreground="#94A3B8" Margin="0,16,0,0" />
                <TextBox Grid.Column="1" 
                         Text="{Binding NewDevice.S7Slot}" 
                         Background="#1E1E2E" 
                         Foreground="#E2E8F0"
                         BorderBrush="#2A2A4A"
                         Margin="0,12,0,0"
                         Padding="8" />
                
                <TextBlock Grid.Column="0" Text="超时时间(ms)" Foreground="#94A3B8" Margin="0,16,0,0" />
                <TextBox Grid.Column="1" 
                         Text="{Binding NewDevice.Timeout}" 
                         Background="#1E1E2E" 
                         Foreground="#E2E8F0"
                         BorderBrush="#2A2A4A"
                         Margin="0,12,0,0"
                         Padding="8" />
                
                <TextBlock Grid.Column="0" Text="重试次数" Foreground="#94A3B8" Margin="0,16,0,0" />
                <TextBox Grid.Column="1" 
                         Text="{Binding NewDevice.RetryCount}" 
                         Background="#1E1E2E" 
                         Foreground="#E2E8F0"
                         BorderBrush="#2A2A4A"
                         Margin="0,12,0,0"
                         Padding="8" />
            </Grid>
        </StackPanel>
    </Grid>
</UserControl>