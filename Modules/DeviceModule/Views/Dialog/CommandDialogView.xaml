<UserControl x:Class="DeviceModule.Views.CommandDialogView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:prism="http://prismlibrary.com/"
             Background="White"
             Width="460"
             Padding="16">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="{Binding Title}"
                   FontSize="16"
                   FontWeight="Bold"
                   Foreground="{StaticResource TextPrimaryBrush}"
                   Margin="0,0,0,16" />

        <StackPanel Grid.Row="1" Margin="0,0,0,12">
            <TextBlock Text="命令名称 *"
                       FontSize="12"
                       Foreground="{StaticResource TextSecondaryBrush}"
                       Margin="0,0,0,4" />
            <TextBox Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"
                     Padding="8,6"
                     FontSize="13" />
        </StackPanel>

        <StackPanel Grid.Row="2" Margin="0,0,0,12">
            <TextBlock Text="协议地址"
                       FontSize="12"
                       Foreground="{StaticResource TextSecondaryBrush}"
                       Margin="0,0,0,4"
                       ToolTip="Modbus: 03:1000:2 | S7: 5:128:32 | OPC UA: ns=2;s=Temp" />
            <TextBox Text="{Binding ProtocolAddress, UpdateSourceTrigger=PropertyChanged}"
                     Padding="8,6"
                     FontSize="13"
                     ToolTip="Modbus: 功能码:地址:长度 | S7: DB号:偏移:长度" />
        </StackPanel>

        <StackPanel Grid.Row="3" Margin="0,0,0,12">
            <TextBlock Text="命令类型"
                       FontSize="12"
                       Foreground="{StaticResource TextSecondaryBrush}"
                       Margin="0,0,0,4" />
            <ComboBox ItemsSource="{Binding CommandTypes}"
                      SelectedItem="{Binding CommandType}"
                      Padding="8,6"
                      FontSize="13" />
        </StackPanel>

        <TextBlock Grid.Row="4"
                   Text="带 * 的字段为必填项"
                   FontSize="11"
                   Foreground="{StaticResource TextSecondaryBrush}"
                   VerticalAlignment="Bottom"
                   Margin="0,0,0,12" />

        <StackPanel Grid.Row="5"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,8,0,0">
            <Button Content="取消"
                    Command="{Binding CancelCommand}"
                    Width="80"
                    Height="32"
                    Margin="0,0,8,0"
                    Background="#E5E7EB"
                    Foreground="#374151" />
            <Button Content="确定"
                    Command="{Binding ConfirmCommand}"
                    Width="80"
                    Height="32"
                    Background="#3B82F6"
                    Foreground="White" />
        </StackPanel>
    </Grid>
</UserControl>
