<UserControl x:Class="DeviceModule.Views.CompleteView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:DeviceModule.ViewModels"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             Background="#0F1626">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="60" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        
        <Border Grid.Row="0" Background="#1E1E2E" CornerRadius="8" Padding="16">
            <TextBlock Text="完成" FontSize="14" FontWeight="Bold" Foreground="#E2E8F0" />
        </Border>
        
        <StackPanel Grid.Row="1" Margin="0,16,0,0" HorizontalAlignment="Center" VerticalAlignment="Center">
            <Border Width="120" Height="120" CornerRadius="60" Background="#22C55E" Margin="0,0,0,24">
                <materialDesign:PackIcon Kind="Check" Width="60" Height="60" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" />
            </Border>
            
            <TextBlock Text="设备配置完成" FontSize="24" FontWeight="Bold" Foreground="#E2E8F0" Margin="0,0,0,8" />
            <TextBlock Text="设备已成功添加到设备列表" FontSize="14" Foreground="#6B7280" />
            
            <StackPanel Orientation="Horizontal" Margin="0,24,0,0">
                <TextBlock Text="设备名称: " Foreground="#94A3B8" />
                <TextBlock Text="{Binding NewDevice.Name}" Foreground="#E2E8F0" />
            </StackPanel>
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="通讯协议: " Foreground="#94A3B8" />
                <TextBlock Text="{Binding NewDevice.ProtocolType}" Foreground="#E2E8F0" />
            </StackPanel>
            
            <Button Style="{StaticResource PrimaryButtonStyle}"
                    Command="{Binding AddAnotherDeviceCommand}"
                    Width="180" Height="40"
                    Margin="0,24,0,0">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <materialDesign:PackIcon Kind="Plus" Width="16" Height="16" Foreground="White" />
                    <TextBlock Text="添加另一个设备" Foreground="White" Margin="8,0,0,0" />
                </StackPanel>
            </Button>
        </StackPanel>
    </Grid>
</UserControl>