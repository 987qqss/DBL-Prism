<UserControl x:Class="DeviceModule.Views.DeviceStateView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource ContentBackground}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- ═══ 上半部分：设备状态信息 ═══ -->
        <Border Grid.Row="0" Style="{StaticResource PanelBorderStyle}" Margin="0,0,0,8">
            <StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                    <TextBlock Text="🖥️" FontSize="14" Foreground="{StaticResource AccentCyanBrush}" VerticalAlignment="Center" />
                    <TextBlock Text="设备状态"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               FontSize="14" FontWeight="Bold"
                               VerticalAlignment="Center" Margin="8,0,0,0" />
                </StackPanel>

                <!-- 设备名称 -->
                <Grid Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="80" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="设备名称"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               FontSize="12" VerticalAlignment="Center" />
                    <TextBlock Grid.Column="1" Text="{Binding DeviceName}"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               FontSize="13" FontWeight="SemiBold"
                               VerticalAlignment="Center" />
                </Grid>

                <!-- 连接状态 -->
                <Grid Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="80" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="连接状态"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               FontSize="12" VerticalAlignment="Center" />
                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                        <Ellipse Width="10" Height="10"
                                 Fill="{Binding ConnectionColor}"
                                 VerticalAlignment="Center" />
                        <TextBlock Text="{Binding ConnectionStatus}"
                                   Foreground="{Binding ConnectionColor}"
                                   FontSize="13" VerticalAlignment="Center"
                                   Margin="6,0,0,0" />
                    </StackPanel>
                </Grid>

                <!-- 协议类型 -->
                <Grid Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="80" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="通讯协议"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               FontSize="12" VerticalAlignment="Center" />
                    <TextBlock Grid.Column="1" Text="{Binding ProtocolType}"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               FontSize="13" VerticalAlignment="Center" />
                </Grid>

                <!-- 协议详情 -->
                <Grid Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="80" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="协议参数"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               FontSize="12" VerticalAlignment="Center" />
                    <TextBlock Grid.Column="1" Text="{Binding ProtocolDetail}"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               FontSize="12" VerticalAlignment="Center"
                               TextWrapping="Wrap" />
                </Grid>

                <!-- 设备 ID -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="80" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="设备 ID"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               FontSize="12" VerticalAlignment="Center" />
                    <TextBlock Grid.Column="1" Text="{Binding DeviceId}"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               FontSize="11" VerticalAlignment="Center"
                               FontFamily="Consolas" />
                </Grid>
            </StackPanel>
        </Border>

        <!-- ═══ 下半部分：数据点列表 ═══ -->
        <Border Grid.Row="1" Style="{StaticResource PanelBorderStyle}" Padding="8">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0"
                           Text="📊 数据点列表"
                           Foreground="{StaticResource AccentCyanBrush}"
                           FontSize="13" FontWeight="Bold"
                           Margin="4,0,0,4" />

                <!-- 表头 -->
                <Border Grid.Row="1" Background="#15FFFFFF" CornerRadius="4"
                        Padding="8,4" Margin="4,0,4,4">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="50" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" MinWidth="60" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="名称"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   FontSize="11" FontWeight="Bold" />
                        <TextBlock Grid.Column="1" Text="类型"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   FontSize="11" FontWeight="Bold"
                                   HorizontalAlignment="Center" />
                        <TextBlock Grid.Column="2" Text="协议地址"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   FontSize="11" FontWeight="Bold"
                                   Margin="8,0,0,0" />
                        <TextBlock Grid.Column="3" Text="写入值"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   FontSize="11" FontWeight="Bold"
                                   HorizontalAlignment="Right"
                                   Margin="4,0,0,0" />
                    </Grid>
                </Border>

                <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
                    <ListBox ItemsSource="{Binding DataPoints}"
                             Background="Transparent" BorderThickness="0">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Background="#0AFFFFFF" CornerRadius="4"
                                        Padding="8,5" Margin="0,0,0,3">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="50" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" MinWidth="60" />
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Grid.Column="0" Text="{Binding Name}"
                                                   Foreground="{StaticResource TextPrimaryBrush}"
                                                   FontSize="12" VerticalAlignment="Center"
                                                   TextTrimming="CharacterEllipsis" />
                                        <TextBlock Grid.Column="1" Text="{Binding CommandType}"
                                                   Foreground="{StaticResource AccentCyanBrush}"
                                                   FontSize="11" FontWeight="SemiBold"
                                                   VerticalAlignment="Center"
                                                   HorizontalAlignment="Center" />
                                        <TextBlock Grid.Column="2" Text="{Binding ProtocolAddress}"
                                                   Foreground="{StaticResource TextSecondaryBrush}"
                                                   FontSize="11" FontFamily="Consolas"
                                                   VerticalAlignment="Center"
                                                   Margin="8,0,0,0" />
                                        <TextBlock Grid.Column="3" Text="{Binding Value}"
                                                   Foreground="{StaticResource AccentAmberBrush}"
                                                   FontSize="12" FontWeight="SemiBold"
                                                   VerticalAlignment="Center"
                                                   HorizontalAlignment="Right"
                                                   Margin="4,0,0,0" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>

                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Background" Value="Transparent" />
                                <Setter Property="BorderThickness" Value="0" />
                                <Setter Property="Padding" Value="0" />
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListBoxItem">
                                            <ContentPresenter />
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ListBox.ItemContainerStyle>
                    </ListBox>
                </ScrollViewer>
            </Grid>
        </Border>
    </Grid>
</UserControl>