<UserControl x:Class="DeviceModule.Views.ProtocolSelectView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:DeviceModule.ViewModels"
             xmlns:m="clr-namespace:Core.Models;assembly=Core"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
             Background="#0F1626">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="60" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        
        <Border Grid.Row="0" Background="#1E1E2E" CornerRadius="8" Padding="16">
            <TextBlock Text="选择通讯协议" FontSize="14" FontWeight="Bold" Foreground="#E2E8F0" />
        </Border>
        
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <WrapPanel Orientation="Horizontal" Margin="0,16,0,0">
                <Border Width="200" Height="120" Margin="0,0,16,16" 
                        BorderBrush="#2A2A4A" BorderThickness="1" CornerRadius="8"
                        Background="#1E1E2E" Cursor="Hand">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding NewDevice.ProtocolType}" Value="{x:Static m:ProtocolType.ModbusTcp}">
                                    <Setter Property="BorderBrush" Value="#3B82F6" />
                                    <Setter Property="Background" Value="#1E3A5F" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                        <materialDesign:PackIcon Kind="Network" Width="40" Height="40" Foreground="#3B82F6" />
                        <TextBlock Text="Modbus TCP" Foreground="#E2E8F0" FontSize="14" Margin="0,8,0,0" />
                        <TextBlock Text="基于TCP/IP的Modbus协议" Foreground="#6B7280" FontSize="11" Margin="0,4,0,0" />
                    </StackPanel>
                    <i:Interaction.Triggers>
                        <i:EventTrigger EventName="MouseLeftButtonDown">
                            <i:InvokeCommandAction Command="{Binding SelectProtocolCommand}" CommandParameter="{x:Static m:ProtocolType.ModbusTcp}" />
                        </i:EventTrigger>
                    </i:Interaction.Triggers>
                </Border>
                
                <Border Width="200" Height="120" Margin="0,0,16,16" 
                        BorderBrush="#2A2A4A" BorderThickness="1" CornerRadius="8"
                        Background="#1E1E2E" Cursor="Hand">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding NewDevice.ProtocolType}" Value="{x:Static m:ProtocolType.ModbusRtu}">
                                    <Setter Property="BorderBrush" Value="#3B82F6" />
                                    <Setter Property="Background" Value="#1E3A5F" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                        <materialDesign:PackIcon Kind="SerialPort" Width="40" Height="40" Foreground="#10B981" />
                        <TextBlock Text="Modbus RTU" Foreground="#E2E8F0" FontSize="14" Margin="0,8,0,0" />
                        <TextBlock Text="基于串口的Modbus协议" Foreground="#6B7280" FontSize="11" Margin="0,4,0,0" />
                    </StackPanel>
                    <i:Interaction.Triggers>
                        <i:EventTrigger EventName="MouseLeftButtonDown">
                            <i:InvokeCommandAction Command="{Binding SelectProtocolCommand}" CommandParameter="{x:Static m:ProtocolType.ModbusRtu}" />
                        </i:EventTrigger>
                    </i:Interaction.Triggers>
                </Border>
                
                <Border Width="200" Height="120" Margin="0,0,16,16" 
                        BorderBrush="#2A2A4A" BorderThickness="1" CornerRadius="8"
                        Background="#1E1E2E" Cursor="Hand">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding NewDevice.ProtocolType}" Value="{x:Static m:ProtocolType.S7}">
                                    <Setter Property="BorderBrush" Value="#3B82F6" />
                                    <Setter Property="Background" Value="#1E3A5F" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                        <materialDesign:PackIcon Kind="Cpu" Width="40" Height="40" Foreground="#F59E0B" />
                        <TextBlock Text="西门子 S7" Foreground="#E2E8F0" FontSize="14" Margin="0,8,0,0" />
                        <TextBlock Text="S7-300/400/1200/1500" Foreground="#6B7280" FontSize="11" Margin="0,4,0,0" />
                    </StackPanel>
                    <i:Interaction.Triggers>
                        <i:EventTrigger EventName="MouseLeftButtonDown">
                            <i:InvokeCommandAction Command="{Binding SelectProtocolCommand}" CommandParameter="{x:Static m:ProtocolType.S7}" />
                        </i:EventTrigger>
                    </i:Interaction.Triggers>
                </Border>
                
                <Border Width="200" Height="120" Margin="0,0,16,16" 
                        BorderBrush="#2A2A4A" BorderThickness="1" CornerRadius="8"
                        Background="#1E1E2E" Cursor="Hand">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding NewDevice.ProtocolType}" Value="{x:Static m:ProtocolType.TcpIp}">
                                    <Setter Property="BorderBrush" Value="#3B82F6" />
                                    <Setter Property="Background" Value="#1E3A5F" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                        <materialDesign:PackIcon Kind="Wifi" Width="40" Height="40" Foreground="#8B5CF6" />
                        <TextBlock Text="TCP/IP" Foreground="#E2E8F0" FontSize="14" Margin="0,8,0,0" />
                        <TextBlock Text="自定义TCP协议" Foreground="#6B7280" FontSize="11" Margin="0,4,0,0" />
                    </StackPanel>
                    <i:Interaction.Triggers>
                        <i:EventTrigger EventName="MouseLeftButtonDown">
                            <i:InvokeCommandAction Command="{Binding SelectProtocolCommand}" CommandParameter="{x:Static m:ProtocolType.TcpIp}" />
                        </i:EventTrigger>
                    </i:Interaction.Triggers>
                </Border>
                
                <Border Width="200" Height="120" Margin="0,0,16,16" 
                        BorderBrush="#2A2A4A" BorderThickness="1" CornerRadius="8"
                        Background="#1E1E2E" Cursor="Hand">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding NewDevice.ProtocolType}" Value="{x:Static m:ProtocolType.OpcUa}">
                                    <Setter Property="BorderBrush" Value="#3B82F6" />
                                    <Setter Property="Background" Value="#1E3A5F" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                        <materialDesign:PackIcon Kind="Globe" Width="40" Height="40" Foreground="#EC4899" />
                        <TextBlock Text="OPC UA" Foreground="#E2E8F0" FontSize="14" Margin="0,8,0,0" />
                        <TextBlock Text="工业标准通信协议" Foreground="#6B7280" FontSize="11" Margin="0,4,0,0" />
                    </StackPanel>
                    <i:Interaction.Triggers>
                        <i:EventTrigger EventName="MouseLeftButtonDown">
                            <i:InvokeCommandAction Command="{Binding SelectProtocolCommand}" CommandParameter="{x:Static m:ProtocolType.OpcUa}" />
                        </i:EventTrigger>
                    </i:Interaction.Triggers>
                </Border>
                
                <Border Width="200" Height="120" Margin="0,0,16,16" 
                        BorderBrush="#2A2A4A" BorderThickness="1" CornerRadius="8"
                        Background="#1E1E2E" Cursor="Hand">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding NewDevice.ProtocolType}" Value="{x:Static m:ProtocolType.Custom}">
                                    <Setter Property="BorderBrush" Value="#3B82F6" />
                                    <Setter Property="Background" Value="#1E3A5F" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                        <materialDesign:PackIcon Kind="Code" Width="40" Height="40" Foreground="#6B7280" />
                        <TextBlock Text="自定义协议" Foreground="#E2E8F0" FontSize="14" Margin="0,8,0,0" />
                        <TextBlock Text="用户自定义协议" Foreground="#6B7280" FontSize="11" Margin="0,4,0,0" />
                    </StackPanel>
                    <i:Interaction.Triggers>
                        <i:EventTrigger EventName="MouseLeftButtonDown">
                            <i:InvokeCommandAction Command="{Binding SelectProtocolCommand}" CommandParameter="{x:Static m:ProtocolType.Custom}" />
                        </i:EventTrigger>
                    </i:Interaction.Triggers>
                </Border>
            </WrapPanel>
        </ScrollViewer>
    </Grid>
</UserControl>