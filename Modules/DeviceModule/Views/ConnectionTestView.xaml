<UserControl x:Class="DeviceModule.Views.ConnectionTestView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:DeviceModule.ViewModels"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             Background="#0F1626">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="60" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        
        <Border Grid.Row="0" Background="#1E1E2E" CornerRadius="8" Padding="16">
            <TextBlock Text="测试连接" FontSize="14" FontWeight="Bold" Foreground="#E2E8F0" />
        </Border>
        
        <StackPanel Grid.Row="1" Margin="0,16,0,0">
            <Border Background="#1E1E2E" CornerRadius="8" Padding="24">
                <StackPanel>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="设备信息" FontSize="14" FontWeight="Bold" Foreground="#E2E8F0" Margin="0,0,0,12" />
                            <TextBlock Text="设备名称: " Foreground="#94A3B8" />
                            <TextBlock Text="{Binding NewDevice.Name}" Foreground="#E2E8F0" Margin="8,0,0,4" />
                            <TextBlock Text="通讯协议: " Foreground="#94A3B8" />
                            <TextBlock Text="{Binding NewDevice.ProtocolType}" Foreground="#E2E8F0" Margin="8,0,0,4" />
                            <TextBlock Text="IP地址: " Foreground="#94A3B8" />
                            <TextBlock Text="{Binding NewDevice.IpAddress}" Foreground="#E2E8F0" Margin="8,0,0,4" />
                            <TextBlock Text="端口: " Foreground="#94A3B8" />
                            <TextBlock Text="{Binding NewDevice.Port}" Foreground="#E2E8F0" Margin="8,0,0,4" />
                        </StackPanel>
                        
                        <Button Grid.Column="1" 
                                Style="{StaticResource PrimaryButtonStyle}"
                                Command="{Binding TestConnectionCommand}"
                                Width="120" Height="40">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <materialDesign:PackIcon Kind="Refresh" Width="16" Height="16" Foreground="White" />
                                <TextBlock Text="测试连接" Foreground="White" Margin="8,0,0,0" />
                            </StackPanel>
                        </Button>
                    </Grid>
                    
                    <Border x:Name="ResultBorder" 
                            Background="#161625" 
                            CornerRadius="8" 
                            Padding="16"
                            Margin="0,16,0,0">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <Ellipse x:Name="ResultIcon" Width="24" Height="24" Margin="0,0,12,0" />
                                <TextBlock x:Name="ResultText" FontSize="14" Foreground="#E2E8F0" />
                            </StackPanel>
                            <TextBlock x:Name="ResultDetails" Foreground="#6B7280" FontSize="12" Margin="36,8,0,0" />
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>
        </StackPanel>
    </Grid>
</UserControl>