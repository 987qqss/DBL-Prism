<UserControl x:Class="Shell.Views.Controls.StatusParamView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- 设备状态 -->
        <Border Grid.Row="0" Style="{StaticResource PanelBorderStyle}" Margin="0,0,0,8">
            <StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                    <TextBlock Text="🖥️" FontSize="16" Foreground="{StaticResource AccentCyanBrush}" VerticalAlignment="Center" />
                    <TextBlock Text="设备状态"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               FontSize="14"
                               FontWeight="Bold"
                               VerticalAlignment="Center"
                               Margin="8,0,0,0" />
                </StackPanel>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Text="连接状态" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,4" />
                    <StackPanel Grid.Row="0" Grid.Column="1" Orientation="Horizontal" Margin="0,4">
                        <Ellipse Width="10" Height="10" Fill="#22C55E" VerticalAlignment="Center" />
                        <TextBlock Text="已连接" Foreground="#22C55E" Margin="6,0,0,0" />
                    </StackPanel>

                    <TextBlock Grid.Row="1" Grid.Column="0" Text="通讯协议" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,4" />
                    <TextBlock Grid.Row="1" Grid.Column="1" Text="Modbus TCP" Foreground="{StaticResource TextPrimaryBrush}" Margin="0,4" />

                    <TextBlock Grid.Row="2" Grid.Column="0" Text="从站地址" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,4" />
                    <TextBlock Grid.Row="2" Grid.Column="1" Text="1" Foreground="{StaticResource TextPrimaryBrush}" Margin="0,4" />

                    <TextBlock Grid.Row="3" Grid.Column="0" Text="轮询周期" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,4" />
                    <TextBlock Grid.Row="3" Grid.Column="1" Text="1000 ms" Foreground="{StaticResource TextPrimaryBrush}" Margin="0,4" />
                </Grid>
            </StackPanel>
        </Border>

        <!-- 参数设置 -->
        <Border Grid.Row="1" Style="{StaticResource PanelBorderStyle}">
            <StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                    <TextBlock Text="⚙" FontSize="16" Foreground="{StaticResource AccentCyanBrush}" VerticalAlignment="Center" />
                    <TextBlock Text="参数设置"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               FontSize="14"
                               FontWeight="Bold"
                               VerticalAlignment="Center"
                               Margin="8,0,0,0" />
                </StackPanel>

                <TextBlock Text="温度上限 (℃)" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,8,0,4" />
                <TextBox Text="60" 
                         Background="{StaticResource PanelBackground}"
                         Foreground="{StaticResource TextPrimaryBrush}"
                         BorderBrush="{StaticResource BorderBrushDark}"
                         BorderThickness="1"
                         Margin="0,0,0,4" />

                <TextBlock Text="温度下限 (℃)" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,8,0,4" />
                <TextBox Text="0" 
                         Background="{StaticResource PanelBackground}"
                         Foreground="{StaticResource TextPrimaryBrush}"
                         BorderBrush="{StaticResource BorderBrushDark}"
                         BorderThickness="1"
                         Margin="0,0,0,4" />

                <TextBlock Text="湿度上限 (%RH)" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,8,0,4" />
                <TextBox Text="80" 
                         Background="{StaticResource PanelBackground}"
                         Foreground="{StaticResource TextPrimaryBrush}"
                         BorderBrush="{StaticResource BorderBrushDark}"
                         BorderThickness="1"
                         Margin="0,0,0,4" />

                <Button Content="保存参数"
                        Style="{StaticResource MenuFlatButtonStyle}"
                        Background="{StaticResource AccentCyanBrush}"
                        Foreground="Black"
                        Margin="0,16,0,0"
                        HorizontalAlignment="Right" />
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
