<UserControl x:Class="Shell.Views.Controls.CommandRunView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- 标题栏 -->
        <Border Grid.Row="0" Style="{StaticResource PanelBorderStyle}" Margin="0,0,0,8">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="▶" FontSize="20" Foreground="{StaticResource AccentCyanBrush}" VerticalAlignment="Center" />
                <TextBlock Text="设备命令执行信息"
                           Foreground="{StaticResource TextPrimaryBrush}"
                           FontSize="16"
                           FontWeight="Bold"
                           VerticalAlignment="Center"
                           Margin="10,0,0,0" />
            </StackPanel>
        </Border>

        <!-- 命令按钮区 -->
        <Border Grid.Row="1" Style="{StaticResource PanelBorderStyle}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,12">
                    <Button Content="读取数据"
                            Command="{Binding ReadCommand}"
                            Style="{StaticResource MenuFlatButtonStyle}"
                            Background="{StaticResource AccentCyanBrush}"
                            Foreground="Black"
                            Margin="0,0,8,0" />
                    <Button Content="写入数据"
                            Command="{Binding WriteCommand}"
                            Style="{StaticResource MenuFlatButtonStyle}"
                            Background="{StaticResource AccentCyanBrush}"
                            Foreground="Black"
                            Margin="0,0,8,0" />
                    <Button Content="启停控制"
                            Command="{Binding StartStopCommand}"
                            Style="{StaticResource MenuFlatButtonStyle}"
                            Background="{StaticResource AccentCyanBrush}"
                            Foreground="Black"
                            Margin="0,0,8,0" />
                    <Button Content="刷新状态"
                            Command="{Binding RefreshCommand}"
                            Style="{StaticResource MenuFlatButtonStyle}"
                            BorderBrush="{StaticResource AccentCyanBrush}"
                            BorderThickness="1" />
                </StackPanel>

                <DataGrid Grid.Row="1"
                          ItemsSource="{Binding CommandHistory}"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          IsReadOnly="True"
                          Background="Transparent"
                          Foreground="{StaticResource TextPrimaryBrush}"
                          BorderBrush="{StaticResource BorderBrushDark}"
                          GridLinesVisibility="Horizontal"
                          HorizontalGridLinesBrush="{StaticResource BorderBrushDark}"
                          RowBackground="Transparent"
                          AlternatingRowBackground="#11FFFFFF">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="时间" Binding="{Binding Time}" Width="160" />
                        <DataGridTextColumn Header="命令" Binding="{Binding Command}" Width="*" />
                        <DataGridTextColumn Header="状态" Binding="{Binding Status}" Width="100" />
                        <DataGridTextColumn Header="结果" Binding="{Binding Result}" Width="200" />
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>
    </Grid>
</UserControl>
