<UserControl x:Class="Shell.Views.Controls.LogView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent">

    <Border Style="{StaticResource PanelBorderStyle}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
                <TextBlock Text="📜" FontSize="16" Foreground="{StaticResource AccentCyanBrush}" VerticalAlignment="Center" />
                <TextBlock Text="日志界面"
                           Foreground="{StaticResource TextPrimaryBrush}"
                           FontSize="14"
                           FontWeight="Bold"
                           VerticalAlignment="Center"
                           Margin="8,0,0,0" />
            </StackPanel>

            <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,8">
                <ComboBox Width="120" Margin="0,0,8,0" SelectedIndex="0"
                          Background="{StaticResource PanelBackground}"
                          Foreground="{StaticResource TextPrimaryBrush}"
                          BorderBrush="{StaticResource BorderBrushDark}"
                          BorderThickness="1">
                    <ComboBoxItem Content="全部" />
                    <ComboBoxItem Content="信息" />
                    <ComboBoxItem Content="警告" />
                    <ComboBoxItem Content="错误" />
                </ComboBox>
                <Button Content="清空" Style="{StaticResource MenuFlatButtonStyle}" Margin="0,0,8,0" />
                <Button Content="导出" Style="{StaticResource MenuFlatButtonStyle}" />
            </StackPanel>

            <ListBox Grid.Row="2"
                     x:Name="LogList"
                     Background="#0A0A1A"
                     BorderBrush="{StaticResource BorderBrushDark}"
                     BorderThickness="1"
                     Foreground="{StaticResource TextPrimaryBrush}"
                     FontFamily="Consolas"
                     FontSize="12"
                     ScrollViewer.HorizontalScrollBarVisibility="Auto">
                <ListBoxItem>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="[10:23:45]" Foreground="{StaticResource TextSecondaryBrush}" />
                        <TextBlock Text=" [INFO] " Foreground="{StaticResource AccentCyanBrush}" />
                        <TextBlock Text="系统启动完成" Foreground="{StaticResource TextPrimaryBrush}" />
                    </StackPanel>
                </ListBoxItem>
                <ListBoxItem>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="[10:23:46]" Foreground="{StaticResource TextSecondaryBrush}" />
                        <TextBlock Text=" [INFO] " Foreground="{StaticResource AccentCyanBrush}" />
                        <TextBlock Text="连接 PLC 成功" Foreground="{StaticResource TextPrimaryBrush}" />
                    </StackPanel>
                </ListBoxItem>
                <ListBoxItem>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="[10:24:12]" Foreground="{StaticResource TextSecondaryBrush}" />
                        <TextBlock Text=" [WARN] " Foreground="{StaticResource AccentAmberBrush}" />
                        <TextBlock Text="温度接近阈值 45℃" Foreground="{StaticResource TextPrimaryBrush}" />
                    </StackPanel>
                </ListBoxItem>
                <ListBoxItem>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="[10:25:30]" Foreground="{StaticResource TextSecondaryBrush}" />
                        <TextBlock Text=" [INFO] " Foreground="{StaticResource AccentCyanBrush}" />
                        <TextBlock Text="开始数据轮询" Foreground="{StaticResource TextPrimaryBrush}" />
                    </StackPanel>
                </ListBoxItem>
            </ListBox>
        </Grid>
    </Border>
</UserControl>
