<UserControl x:Class="Shell.Views.MenuBarView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:prism="http://prismlibrary.com/"
             xmlns:vm="clr-namespace:Shell.ViewModels"
             xmlns:m="clr-namespace:Shell.Models"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             prism:ViewModelLocator.AutoWireViewModel="True"
             d:DataContext="{d:DesignInstance Type=vm:MenuBarViewModel, IsDesignTimeCreatable=False}"
             mc:Ignorable="d"
             Background="{StaticResource MenuBarBackground}">

    <UserControl.Resources>
        <!-- 菜单项内部模板（Button） -->
        <DataTemplate x:Key="MenuItemTemplate" DataType="{x:Type m:MenuItemModel}">
            <Button Command="{Binding Command}"
                    HorizontalContentAlignment="Stretch"
                    Background="Transparent"
                    BorderThickness="0"
                    Height="30"
                    Padding="10,0"
                    Cursor="Hand">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="18" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0"
                                           Text="●"
                                           FontSize="9"
                                           VerticalAlignment="Center"
                                           Foreground="{StaticResource AccentCyanBrush}" />
                                <TextBlock Grid.Column="1"
                                           Text="{Binding Header}"
                                           Foreground="White"
                                           FontSize="12"
                                           VerticalAlignment="Center"
                                           Margin="8,0,0,0" />
                                <TextBlock Grid.Column="2"
                                           Text="{Binding InputGestureText}"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           FontSize="10"
                                           VerticalAlignment="Center"
                                           Margin="16,0,0,0" />
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#22FFFFFF" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>
        </DataTemplate>

        <!-- 下拉内容面板 -->
        <DataTemplate x:Key="MenuDropdownContent">
            <Border Background="#1B1B2F"
                    BorderBrush="{StaticResource BorderBrushDark}"
                    BorderThickness="1"
                    CornerRadius="6"
                    Padding="4"
                    MinWidth="170">
                <ItemsControl ItemsSource="{Binding}"
                              ItemTemplate="{StaticResource MenuItemTemplate}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                </ItemsControl>
            </Border>
        </DataTemplate>

        <!-- 菜单按钮样式（触发 Popup 的 ToggleButton） -->
        <Style x:Key="MenuBarToggleStyle" TargetType="ToggleButton">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="10,0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}"
                                VerticalAlignment="Stretch">
                            <ContentPresenter VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#22FFFFFF" />
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#3300D4FF" />
                                <Setter Property="Foreground" Value="{StaticResource AccentCyanBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>

        <!-- ═══ 左侧：汉堡按钮 + 菜单按钮 ═══ -->
        <StackPanel Grid.Column="0" Orientation="Horizontal" Margin="4,0">

            <!-- 汉堡按钮 -->
            <Button Style="{StaticResource HamburgerButtonStyle}"
                    Command="{Binding ToggleSidebarCommand}"
                    ToolTip="切换导航栏"
                    Margin="0,0,2,0" />

            <!-- 文件 -->
            <ToggleButton x:Name="BtnFile"
                          Style="{StaticResource MenuBarToggleStyle}"
                          ToolTip="文件操作"
>
                    <TextBlock Text="文件" FontSize="12" />
                </ToggleButton>
                <Popup x:Name="PopFile"
                       PlacementTarget="{Binding ElementName=BtnFile}"
                       Placement="Bottom"
                       StaysOpen="False"
                       AllowsTransparency="True"
                       PopupAnimation="Fade"
                       IsOpen="{Binding IsChecked, ElementName=BtnFile}">
                    <ContentControl Content="{Binding FileMenuItems}"
                                    ContentTemplate="{StaticResource MenuDropdownContent}" />
                </Popup>

            <!-- 编辑 -->
            <ToggleButton x:Name="BtnEdit"
                          Style="{StaticResource MenuBarToggleStyle}"
                          ToolTip="编辑操作"
>
                    <TextBlock Text="编辑" FontSize="12" />
                </ToggleButton>
                <Popup x:Name="PopEdit"
                       PlacementTarget="{Binding ElementName=BtnEdit}"
                       Placement="Bottom"
                       StaysOpen="False"
                       AllowsTransparency="True"
                       PopupAnimation="Fade"
                       IsOpen="{Binding IsChecked, ElementName=BtnEdit}">
                    <ContentControl Content="{Binding EditMenuItems}"
                                    ContentTemplate="{StaticResource MenuDropdownContent}" />
                </Popup>

            <!-- 视图 -->
            <ToggleButton x:Name="BtnView"
                          Style="{StaticResource MenuBarToggleStyle}"
                          ToolTip="切换视图"
>
                    <TextBlock Text="视图" FontSize="12" />
                </ToggleButton>
                <Popup x:Name="PopView"
                       PlacementTarget="{Binding ElementName=BtnView}"
                       Placement="Bottom"
                       StaysOpen="False"
                       AllowsTransparency="True"
                       PopupAnimation="Fade"
                       IsOpen="{Binding IsChecked, ElementName=BtnView}">
                    <ContentControl Content="{Binding ViewMenuItems}"
                                    ContentTemplate="{StaticResource MenuDropdownContent}" />
                </Popup>

            <!-- 工具 -->
            <ToggleButton x:Name="BtnTools"
                          Style="{StaticResource MenuBarToggleStyle}"
                          ToolTip="设备工具"
>
                    <TextBlock Text="工具" FontSize="12" />
                </ToggleButton>
                <Popup x:Name="PopTools"
                       PlacementTarget="{Binding ElementName=BtnTools}"
                       Placement="Bottom"
                       StaysOpen="False"
                       AllowsTransparency="True"
                       PopupAnimation="Fade"
                       IsOpen="{Binding IsChecked, ElementName=BtnTools}">
                    <ContentControl Content="{Binding ToolsMenuItems}"
                                    ContentTemplate="{StaticResource MenuDropdownContent}" />
                </Popup>

            <!-- 用户 -->
            <ToggleButton x:Name="BtnUser"
                          Style="{StaticResource MenuBarToggleStyle}"
                          ToolTip="用户管理"
>
                    <TextBlock Text="用户" FontSize="12" />
                </ToggleButton>
                <Popup x:Name="PopUser"
                       PlacementTarget="{Binding ElementName=BtnUser}"
                       Placement="Bottom"
                       StaysOpen="False"
                       AllowsTransparency="True"
                       PopupAnimation="Fade"
                       IsOpen="{Binding IsChecked, ElementName=BtnUser}">
                    <ContentControl Content="{Binding UserMenuItems}"
                                    ContentTemplate="{StaticResource MenuDropdownContent}" />
                </Popup>

        </StackPanel>

        <!-- ═══ 右侧按钮 ═══ -->
        <StackPanel Grid.Column="2" Orientation="Horizontal" Margin="0,0,4,0">

            <Button Style="{StaticResource MenuFlatButtonStyle}"
                    Command="{Binding SettingsCommand}"
                    ToolTip="系统设置">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="⚙" FontSize="11" VerticalAlignment="Center" Margin="0,0,3,0" />
                    <TextBlock Text="设置" FontSize="11" Foreground="White" VerticalAlignment="Center" />
                </StackPanel>
            </Button>

            <Button Style="{StaticResource MenuFlatButtonStyle}"
                    Command="{Binding AboutCommand}"
                    ToolTip="关于本系统">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="i" FontSize="11" VerticalAlignment="Center" Margin="0,0,3,0" />
                    <TextBlock Text="关于" FontSize="11" Foreground="White" VerticalAlignment="Center" />
                </StackPanel>
            </Button>

        </StackPanel>
    </Grid>
</UserControl>