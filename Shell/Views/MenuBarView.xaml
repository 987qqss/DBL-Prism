<UserControl x:Class="Shell.Views.MenuBarView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:prism="http://prismlibrary.com/"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:vm="clr-namespace:Shell.ViewModels"
             xmlns:m="clr-namespace:Shell.Models"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             prism:ViewModelLocator.AutoWireViewModel="True"
             d:DataContext="{d:DesignInstance Type=vm:MenuBarViewModel, IsDesignTimeCreatable=False}"
             mc:Ignorable="d"
             Background="{StaticResource MenuBarBackground}">

    <UserControl.Resources>
        <!-- 单个菜单项模板 -->
        <DataTemplate x:Key="MenuItemTemplate" DataType="{x:Type m:MenuItemModel}">
            <Button Command="{Binding Command}"
                    HorizontalContentAlignment="Stretch"
                    Background="Transparent"
                    BorderThickness="0"
                    Height="34"
                    Padding="12,0"
                    Cursor="Hand">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="22" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0"
                                           Text="●"
                                           FontSize="10"
                                           VerticalAlignment="Center"
                                           Foreground="{StaticResource AccentCyanBrush}" />
                                <TextBlock Grid.Column="1"
                                           Text="{Binding Header}"
                                           Foreground="{StaticResource TextPrimaryBrush}"
                                           FontSize="13"
                                           VerticalAlignment="Center"
                                           Margin="10,0,0,0" />
                                <TextBlock Grid.Column="2"
                                           Text="{Binding InputGestureText}"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           FontSize="11"
                                           VerticalAlignment="Center"
                                           Margin="20,0,0,0" />
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#22FFFFFF" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>
        </DataTemplate>

        <!-- 下拉内容模板（容器） -->
        <DataTemplate x:Key="MenuDropdownContent">
            <Border Background="#1B1B2F"
                    BorderBrush="{StaticResource BorderBrushDark}"
                    BorderThickness="1"
                    CornerRadius="6"
                    Padding="6"
                    MinWidth="180">
                <ItemsControl ItemsSource="{Binding}"
                              ItemTemplate="{StaticResource MenuItemTemplate}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                </ItemsControl>
            </Border>
        </DataTemplate>

        <!-- PopupBox 通用样式 -->
        <Style x:Key="MenuPopupBoxStyle" TargetType="materialDesign:PopupBox">
            <Setter Property="Width" Value="Auto" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="HorizontalAlignment" Value="Left" />
            <Setter Property="VerticalAlignment" Value="Stretch" />
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>

        <!-- ============ 左侧：汉堡按钮 + 下拉菜单按钮 ============ -->
        <StackPanel Grid.Column="0" Orientation="Horizontal" Margin="4,0">
            <!-- 汉堡按钮 -->
            <Button Style="{StaticResource HamburgerButtonStyle}"
                    Command="{Binding ToggleSidebarCommand}"
                    ToolTip="切换导航栏"
                    Margin="0,0,2,0" />

            <materialDesign:PopupBox Style="{StaticResource MenuPopupBoxStyle}"
                                     PlacementMode="BottomAndAlignLeftEdges"
                                     StaysOpen="False"
                                     ToolTip="文件操作">
                <materialDesign:PopupBox.ToggleContent>
                    <Border Padding="12,0" Background="Transparent">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="文件" FontSize="12" VerticalAlignment="Center" />
                            <TextBlock Text="▼" FontSize="8" VerticalAlignment="Center" Margin="4,0,0,0" />
                        </StackPanel>
                    </Border>
                </materialDesign:PopupBox.ToggleContent>
                <ContentControl Content="{Binding FileMenuItems}"
                                ContentTemplate="{StaticResource MenuDropdownContent}" />
            </materialDesign:PopupBox>

            <materialDesign:PopupBox Style="{StaticResource MenuPopupBoxStyle}"
                                     PlacementMode="BottomAndAlignLeftEdges"
                                     StaysOpen="False"
                                     Margin="2,0,0,0"
                                     ToolTip="编辑操作">
                <materialDesign:PopupBox.ToggleContent>
                    <Border Padding="12,0" Background="Transparent">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="编辑" FontSize="12" VerticalAlignment="Center" />
                            <TextBlock Text="▼" FontSize="8" VerticalAlignment="Center" Margin="4,0,0,0" />
                        </StackPanel>
                    </Border>
                </materialDesign:PopupBox.ToggleContent>
                <ContentControl Content="{Binding EditMenuItems}"
                                ContentTemplate="{StaticResource MenuDropdownContent}" />
            </materialDesign:PopupBox>

            <materialDesign:PopupBox Style="{StaticResource MenuPopupBoxStyle}"
                                     PlacementMode="BottomAndAlignLeftEdges"
                                     StaysOpen="False"
                                     Margin="2,0,0,0"
                                     ToolTip="切换视图">
                <materialDesign:PopupBox.ToggleContent>
                    <Border Padding="12,0" Background="Transparent">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="视图" FontSize="12" VerticalAlignment="Center" />
                            <TextBlock Text="▼" FontSize="8" VerticalAlignment="Center" Margin="4,0,0,0" />
                        </StackPanel>
                    </Border>
                </materialDesign:PopupBox.ToggleContent>
                <ContentControl Content="{Binding ViewMenuItems}"
                                ContentTemplate="{StaticResource MenuDropdownContent}" />
            </materialDesign:PopupBox>

            <materialDesign:PopupBox Style="{StaticResource MenuPopupBoxStyle}"
                                     PlacementMode="BottomAndAlignLeftEdges"
                                     StaysOpen="False"
                                     Margin="2,0,0,0"
                                     ToolTip="设备工具">
                <materialDesign:PopupBox.ToggleContent>
                    <Border Padding="12,0" Background="Transparent">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="工具" FontSize="12" VerticalAlignment="Center" />
                            <TextBlock Text="▼" FontSize="8" VerticalAlignment="Center" Margin="4,0,0,0" />
                        </StackPanel>
                    </Border>
                </materialDesign:PopupBox.ToggleContent>
                <ContentControl Content="{Binding ToolsMenuItems}"
                                ContentTemplate="{StaticResource MenuDropdownContent}" />
            </materialDesign:PopupBox>

            <materialDesign:PopupBox Style="{StaticResource MenuPopupBoxStyle}"
                                     PlacementMode="BottomAndAlignLeftEdges"
                                     StaysOpen="False"
                                     Margin="2,0,0,0"
                                     ToolTip="用户管理">
                <materialDesign:PopupBox.ToggleContent>
                    <Border Padding="12,0" Background="Transparent">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="用户" FontSize="12" VerticalAlignment="Center" />
                            <TextBlock Text="▼" FontSize="8" VerticalAlignment="Center" Margin="4,0,0,0" />
                        </StackPanel>
                    </Border>
                </materialDesign:PopupBox.ToggleContent>
                <ContentControl Content="{Binding UserMenuItems}"
                                ContentTemplate="{StaticResource MenuDropdownContent}" />
            </materialDesign:PopupBox>

        </StackPanel>

        <!-- ============ 右侧：普通按钮 ============ -->
        <StackPanel Grid.Column="2" Orientation="Horizontal" Margin="0,0,4,0">

            <Button Style="{StaticResource MenuFlatButtonStyle}"
                    Command="{Binding SettingsCommand}"
                    ToolTip="系统设置">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="⚙" FontSize="12" VerticalAlignment="Center" Margin="0,0,4,0" />
                    <TextBlock Text="设置" FontSize="12" VerticalAlignment="Center" />
                </StackPanel>
            </Button>

            <Button Style="{StaticResource MenuFlatButtonStyle}"
                    Command="{Binding AboutCommand}"
                    ToolTip="关于本系统">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="i" FontSize="12" VerticalAlignment="Center" Margin="0,0,4,0" />
                    <TextBlock Text="关于" FontSize="12" VerticalAlignment="Center" />
                </StackPanel>
            </Button>

        </StackPanel>
    </Grid>
</UserControl>
