<?xml version="1.0" encoding="utf-8" ?>
<nlog xmlns="http://www.nlog-project.org/schemas/NLog.xsd"
      xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      autoReload="true"
      internalLogLevel="Info"
      internalLogFile="NLogInternal.log">

  <targets>
    <target name="file" xsi:type="File"
            fileName="${basedir}/Logs/Log_${shortdate}.txt"
            layout="${longdate} [${level:uppercase=true}] [${logger}] ${message}${onexception:${newline}${exception:format=tostring}}"
            encoding="utf-8"
            maxArchiveFiles="10"
            archiveAboveSize="10485760" />

    <target name="console" xsi:type="Console"
            layout="${longdate} [${level:uppercase=true}] [${logger}] ${message}" />

    <target name="memory" xsi:type="Memory"
            layout="${longdate}|${level:uppercase=true}|${logger}|${message}"
            maxSize="1000" />
  </targets>

  <rules>
    <logger name="*" minlevel="Debug" writeTo="file" />
    <logger name="*" minlevel="Debug" writeTo="console" />
    <logger name="*" minlevel="Debug" writeTo="memory" />
  </rules>
</nlog>